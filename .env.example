# ---------------------------------------------------------------
# Pet API — environment variable reference
# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.
# ---------------------------------------------------------------

# Spring profile: "dev" (verbose logging) or "prod" (silent, health hidden)
SPRING_PROFILES_ACTIVE=dev

# MySQL — overrides spring.datasource.*
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/petdb
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=changeme

# Redis — overrides spring.data.redis.host
SPRING_DATA_REDIS_HOST=localhost

# MongoDB — overrides spring.data.mongodb.uri
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/petdb

# Kafka — overrides spring.kafka.bootstrap-servers
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9093

# JWT
# Generate a 64-char hex string: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_hex_string_never_commit_a_real_value
# Access token lifetime in ms — 900000 = 15 minutes
JWT_EXPIRATION=900000
# Refresh token lifetime in ms — 604800000 = 7 days
JWT_REFRESH_EXPIRATION=604800000

# Zipkin tracing (optional — app starts fine without it)
MANAGEMENT_ZIPKIN_TRACING_ENDPOINT=http://localhost:9411/api/v2/spans
